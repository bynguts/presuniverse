# PresUniverse — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# 1. Whisper.cpp Local Server (Dipakai saat mic ditekan)
#    Jalankan start-all.bat terlebih dahulu!
WHISPER_SERVER_URL=http://localhost:9000/inference
WHISPER_LANGUAGE=en
WHISPER_MODEL=small

# 2. TTS Provider Configuration (edge / local)
# Choose 'local' for Qwen3-TTS or 'edge' for Microsoft Edge TTS
TTS_PROVIDER=edge
LOCAL_TTS_URL=http://localhost:8000/api/tts
LOCAL_TTS_SPEAKER=Vivian
LOCAL_TTS_INSTRUCT=narrate in a friendly, warm, helpful female guide voice

# 3. Microsoft Edge TTS Voice (Only applies when TTS_PROVIDER=edge)
# Rekomendasi Suara Wanita Natural:
# - en-US-AriaNeural (Cocok dengan nama bot ARIA, profesional, ceria)
# - en-US-AvaMultilingualNeural (Sangat natural, lembut, ekspresif)
# - en-US-EmmaMultilingualNeural (Suara default, jelas seperti presenter)
# - en-US-JennyNeural (Sangat ramah, populer)
# - en-GB-SoniaNeural (Aksen British, sangat elegan)
EDGE_TTS_VOICE=en-US-EmmaMultilingualNeural
